# Copy to .env and adjust. .env is gitignored — do not commit real passwords.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=treenotes
POSTGRES_PORT=5432

# FastAPI (local runs outside Docker — host must reach Postgres)
DATABASE_URL=postgresql+psycopg2://postgres:changeme@127.0.0.1:5432/treenotes

# Comma-separated browser origins allowed to call the API (CORS).
# Needed when the UI origin differs from the API (e.g. static server on :8080 → API on :8000).
# With the default Compose stack, the app uses same-origin /api via nginx; CORS is mainly for direct :8000 access or tools.
CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080

# Published API port when using docker compose (optional)
API_PORT=8000

# Static frontend (nginx) port — open http://127.0.0.1:FRONTEND_PORT
FRONTEND_PORT=8080
